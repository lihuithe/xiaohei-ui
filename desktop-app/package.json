{
  "name": "electron-vue3-app",
  "private": true,
  "version": "0.0.0",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "generate:icons": "node scripts/generate-icons.mjs",
    "preview": "vite preview",
    "lint": "eslint . --fix",
    "format": "prettier --write .",
    "type-check": "vue-tsc --noEmit",
    "build:electron": "vue-tsc -b && vite build && electron-builder",
    "build:win": "vue-tsc -b && vite build && electron-builder --win --x64",
    "build:mac": "vue-tsc -b && vite build && electron-builder --mac --x64 --arm64",
    "build:linux": "vue-tsc -b && vite build && electron-builder --linux --x64",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/vue-table": "^8.21.3",
    "@vee-validate/zod": "^4.15.1",
    "@vueuse/core": "^14.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "embla-carousel-vue": "^8.6.0",
    "highlight.js": "^11.11.1",
    "lucide-vue-next": "^1.0.0",
    "markdown-it": "^14.1.1",
    "reka-ui": "^2.9.7",
    "shadcn-vue": "^2.6.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "vaul-vue": "^0.4.1",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.32",
    "vue-i18n": "^9.14.5",
    "vue-input-otp": "^0.3.2",
    "vue-router": "^4.6.4",
    "vue-sonner": "^2.0.9",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/vue": "^8.1.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.9.1",
    "jsdom": "^25.0.1",
    "pngjs": "^7.0.0",
    "prettier": "^3.8.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.10",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.7",
    "vitest": "^2.1.8",
    "@vitest/coverage-v8": "^2.1.8",
    "vue-tsc": "^3.2.7"
  },
  "build": {
    "appId": "com.xiaohei.assistant",
    "productName": "小黑助手",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/icons",
        "to": "icons"
      }
    ],
    "asar": true,
    "compression": "maximum",
    "removePackageScripts": true,
    "mac": {
      "icon": "resources/icons/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ],
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlementsInherit": "resources/entitlements.mac.plist",
      "entitlements": "resources/entitlements.mac.plist"
    },
    "win": {
      "icon": "resources/icons/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "linux": {
      "icon": "resources/icons/icon.png",
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "deb",
          "arch": ["x64"]
        }
      ],
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    }
  }
}
